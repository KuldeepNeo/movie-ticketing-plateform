        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"SecureP@ss1\",\n  \"confirm_password\": \"SecureP@ss1\"\n}"
        },
        "url": {
